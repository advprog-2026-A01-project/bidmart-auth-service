spring.application.name=backend

# Tanggung jawab: konfigurasi datasource + auth props default.

spring.datasource.url=${JDBC_DATABASE_URL:${SPRING_DATASOURCE_URL:jdbc:postgresql://localhost:5433/bidmart}}
spring.datasource.username=${JDBC_DATABASE_USERNAME:${SPRING_DATASOURCE_USERNAME:bidmart}}
spring.datasource.password=${JDBC_DATABASE_PASSWORD:${SPRING_DATASOURCE_PASSWORD:bidmart}}
spring.datasource.driver-class-name=org.postgresql.Driver

admin.bootstrap.enabled=${ADMIN_BOOTSTRAP_ENABLED:false}
admin.bootstrap.username=${ADMIN_BOOTSTRAP_USERNAME:}
admin.bootstrap.password=${ADMIN_BOOTSTRAP_PASSWORD:}

spring.sql.init.mode=always

# --- Auth defaults (safe to tune per milestone) ---
# Access token TTL in minutes
auth.access-ttl-minutes=60
# Refresh token TTL in days
auth.refresh-ttl-days=14
# Max concurrent sessions per user
auth.max-sessions-per-user=5
# REVOKE_OLDEST | REJECT
auth.overflow-policy=REVOKE_OLDEST

# For sending MFA/Verification Code and OTP to user's gmail
spring.mail.host=smtp.gmail.com
spring.mail.port=587
spring.mail.username=${SMTP_USERNAME}
spring.mail.password=${SMTP_PASSWORD}
spring.mail.properties.mail.smtp.auth=true
spring.mail.properties.mail.smtp.starttls.enable=true

# Demo static codes for non-admin users
auth.demo-static-codes-enabled=true
auth.demo-email-verification-code=112233
auth.demo-email-otp-code=445566

# Upload limit for identity document
spring.servlet.multipart.max-file-size=5MB
spring.servlet.multipart.max-request-size=6MB

# For captcha login / register
auth.captcha-enabled=true
auth.captcha-ttl-seconds=180
auth.captcha-length=5
auth.captcha-noise-lines=5
auth.captcha-case-sensitive=true
-- ===== CATALOG & LISTING =====

-- Tabel Kategori dengan dukungan hierarki (Self-referencing)
CREATE TABLE IF NOT EXISTS app_categories (
    id        BIGINT GENERATED BY DEFAULT AS IDENTITY PRIMARY KEY,
    name      VARCHAR(255) NOT NULL,
    parent_id BIGINT       REFERENCES app_categories (id) ON DELETE SET NULL
);

-- Tabel Listing Barang
CREATE TABLE IF NOT EXISTS app_listings (
    id               BIGINT GENERATED BY DEFAULT AS IDENTITY PRIMARY KEY,
    title            VARCHAR(255)             NOT NULL,
    description      TEXT,
    image_url        TEXT,
    category_id      BIGINT                   NOT NULL REFERENCES app_categories (id),
    initial_price    DECIMAL(19, 2)           NOT NULL,
    reserve_price    DECIMAL(19, 2),
    current_price    DECIMAL(19, 2),
    duration_minutes INT                      NOT NULL,
    seller_id        BIGINT                   NOT NULL REFERENCES app_users (id),
    status           VARCHAR(32)              NOT NULL DEFAULT 'ACTIVE', -- ACTIVE, CANCELLED, SOLD, UNSOLD
    created_at       TIMESTAMP WITH TIME ZONE NOT NULL DEFAULT CURRENT_TIMESTAMP,
    updated_at       TIMESTAMP WITH TIME ZONE NOT NULL DEFAULT CURRENT_TIMESTAMP
);

CREATE INDEX IF NOT EXISTS idx_listings_seller_id ON app_listings(seller_id);
CREATE INDEX IF NOT EXISTS idx_listings_category_id ON app_listings(category_id);
CREATE INDEX IF NOT EXISTS idx_listings_status ON app_listings(status);